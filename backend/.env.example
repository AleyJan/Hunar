# =============================================
# HUNAR Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# =============================================

NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/hunar?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=replace_with_long_random_secret_here
JWT_EXPIRES_IN=7d

# Anthropic Claude (Step 1 — Intent Parsing)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Maps Distance Matrix (Step 2 — Provider Matching)
GOOGLE_MAPS_API_KEY=AIzaSy...

# Twilio (Step 5 — SMS/WhatsApp Notifications)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Admin
ADMIN_API_KEY=hunar_admin_secret_replace_me
